# RSCD Replicator — API keys template
# Copy this file to api_keys.env and fill in your keys.
# api_keys.env is gitignored.
#
# FRED (St. Louis Fed) — REQUIRED for Ch2 extensions (INDPRO, UNRATE, M1, M2 ...)
# Register free: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BEA (U.S. Bureau of Economic Analysis) — REQUIRED for Ch5/6 profit rate chain
# Register free: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# BLS (Bureau of Labor Statistics) — OPTIONAL (industry-level)
# Register free: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# World Bank, IMF SDMX, MeasuringWorth — no key required
