# CD2 Replicator — API Keys
# Copy this file to api_keys.env and fill in your keys.
# All APIs offer FREE registration. The pipeline degrades gracefully if keys are missing.

# FRED (Federal Reserve Economic Data) — Required for Ch2 extensions and FRED series
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
# Used by: L01-L07, and all FRED-extended series
FRED_API_KEY=your_fred_api_key_here

# BEA (Bureau of Economic Analysis) — Required for Ch6 profit rate chain
# Register: https://apps.bea.gov/api/signup/
# Used by: L09-L12 (NIPA tables), L17 (Fixed Assets)
BEA_API_KEY=your_bea_api_key_here

# BLS (Bureau of Labor Statistics) — Optional, for industry-level data
# Register: https://data.bls.gov/registrationEngine/
# Used by: (optional industry-level extensions)
BLS_API_KEY=your_bls_api_key_here

# World Bank — NO KEY REQUIRED (open API)
# Used by: L58 (Argentina data)
# API docs: https://datahelpdesk.worldbank.org/knowledgebase/articles/889392
